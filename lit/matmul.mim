plugin tensor;
plugin core;
plugin math;

let f32 = %math.f32;
let F32 = %math.F32;
let R: %tensor.Ring = (F32, 0: F32, %math.arith.add @f32 0, %math.arith.mul @f32 0);


let A: «2; «2; F32»» = ((1.0: F32, 2.0: F32), (3.0: F32, 4.0: F32));
let B: «2; «2; F32»» = ((1.0: F32, 0.0: F32), (0.0: F32, 1.0: F32));

let result = %tensor.product_2d R (A, B);

fun extern main (): «2; «2; F32»» =
    return result;


